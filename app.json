{
  "configVersion": "v3",
  "app": {
    "appId": 1117557,
    "appName": "RainCalendar",
    "appType": "app",
    "version": {
      "code": 4,
      "name": "1.1.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Holiday and solar term calendar app"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/holiday/index.page"
          ]
        },
        "app-widget": {
          "widgets": [
            {
              "path": "page/gt/app-widget/index",
              "icon": "icon.png",
              "runtime": {
                "type": "js"
              },
              "name": "Holiday Card",
              "i18n": {
                "en-US": {
                  "name": "Holiday Card"
                },
                "zh-CN": {
                  "name": "节日卡片"
                }
              }
            }
          ]
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "RainCalendar"
    },
    "zh-CN": {
      "appName": "雨声日历",
      "app-widget": {
        "widgets":[{
          "name": "卡路里"
        }]
      }
    }
  },
  "defaultLanguage": "en-US"
}
